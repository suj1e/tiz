# Tiz Production Deployment Environment Variables
# Copy this file to .env and fill in the values

# ============================================
# Database (connects to infra prod)
# ============================================
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/tiz?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
MYSQL_PASSWORD=<your-mysql-password>

# ============================================
# Redis
# ============================================
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379
REDIS_PASSWORD=<your-redis-password>

# ============================================
# Kafka
# ============================================
SPRING_KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ============================================
# Nacos
# ============================================
NACOS_SERVER_ADDR=nacos:8080
NACOS_NAMESPACE=

# ============================================
# JWT
# ============================================
JWT_SECRET=<your-jwt-secret>

# ============================================
# Elasticsearch
# ============================================
ELASTIC_PASSWORD=<your-elastic-password>

# ============================================
# LLM Service
# ============================================
OPENAI_API_KEY=<your-openai-api-key>
