        {
          "name": "Update AI Config",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"gpt4\",\n  \"temperature\": 0.5,\n  \"max_tokens\": 4096,\n  \"features\": {\n    \"enhance_translation\": true,\n    \"deep_thinking_mode\": true\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/user/ai-config",
              "host": ["{{base_url}}"],
              "path": ["user", "ai-config"]
            },
            "description": "Update user's AI configuration"
          },
          "response": []
