# Tiz AI Service Configuration
# Copy this file to .env and fill in your values

# Service Configuration
SERVICE_NAME=llm-service  # optional
SERVICE_PORT=8106  # optional
DEBUG=false  # optional

# Nacos Configuration
NACOS_ENABLED=true  # optional
NACOS_SERVER_ADDR=localhost:30848  # optional
NACOS_NAMESPACE=  # optional
NACOS_USERNAME=nacos  # optional
NACOS_PASSWORD=nacos  # optional

# LLM Configuration
# API key for your LLM provider (required)
LLM_API_KEY=<your-llm-api-key>

# API URL (default: OpenAI compatible)
# For OpenAI: https://api.openai.com/v1
# For Azure: https://your-resource.openai.azure.com/openai/deployments/your-deployment
# For other providers: check their documentation
LLM_API_URL=https://api.openai.com/v1  # optional

# Model to use
LLM_MODEL=gpt-4o  # optional

# Generation parameters
LLM_TEMPERATURE=0.7  # optional
LLM_MAX_TOKENS=4096  # optional

# Timeout settings (in seconds)
LLM_TIMEOUT=60  # optional
STREAM_TIMEOUT=120  # optional
