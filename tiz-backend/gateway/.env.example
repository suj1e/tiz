# Tiz Gateway Configuration
# Copy this file to .env and fill in your values

# Nacos Discovery
NACOS_SERVER_ADDR=localhost:30848  # optional
NACOS_NAMESPACE=  # optional

# JWT
JWT_SECRET=<your-jwt-secret>

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000  # optional

# Logging
LOGGING_LEVEL_ROOT=INFO  # optional
LOGGING_LEVEL_IO_GITHUB_SUJ1E=DEBUG  # optional
