# Tiz Practice Service Configuration
# Copy this file to .env and fill in your values

# Nacos Discovery
NACOS_SERVER_ADDR=localhost:30848  # optional
NACOS_NAMESPACE=  # optional

# Database
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/tiz?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true  # optional
SPRING_DATASOURCE_USERNAME=root  # optional
MYSQL_PASSWORD=<your-mysql-password>

# Redis
SPRING_DATA_REDIS_HOST=localhost  # optional
SPRING_DATA_REDIS_PORT=6379  # optional
REDIS_PASSWORD=<your-redis-password>

# Kafka
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092  # optional

# LLM Service
LLM_SERVICE_URL=http://localhost:8106  # optional

# Logging
LOGGING_LEVEL_ROOT=INFO  # optional
LOGGING_LEVEL_IO_GITHUB_SUJ1E=DEBUG  # optional
