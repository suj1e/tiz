{
  "name": "tiz-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm dev:desktop",
    "dev:desktop": "vite --config vite.config.desktop.ts",
    "dev:mobile": "vite --config vite.config.mobile.ts",
    "build": "pnpm build:all",
    "build:desktop": "tsc -b && vite build --config vite.config.desktop.ts",
    "build:mobile": "tsc -b && vite build --config vite.config.mobile.ts",
    "build:all": "run-p build:desktop build:mobile",
    "preview": "pnpm preview:desktop",
    "preview:desktop": "vite preview --config vite.config.desktop.ts",
    "preview:mobile": "vite preview --config vite.config.mobile.ts",
    "lint": "eslint . --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "lint-staged": {
    "*": "eslint --fix"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.0",
    "npm-run-all": "^4.1.5",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.0.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.2",
    "msw": "^2.12.10",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "shadcn": "^4.0.2",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
